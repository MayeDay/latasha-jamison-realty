# Frontend Environment Variables
# Used for building and running the React frontend on AppRunner

# Server port (AppRunner will use 3000 by default)
PORT=3000

# API endpoints
VITE_API_URL=https://latasha-backend.YOUR_REGION.apprunner.amazonaws.com
VITE_DOTNET_API_URL=https://latasha-api.YOUR_REGION.apprunner.amazonaws.com

# Environment
VITE_ENVIRONMENT=production
